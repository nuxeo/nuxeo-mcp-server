{
  "mcpServers": {
    "default": {
      "command": "uv",
      "args": ["run", "--frozen", "python", "-m", "nuxeo_mcp"],
      "env": { 
        "NUXEO_URL": "http://localhost:8080/nuxeo",
        "NUXEO_USERNAME": "Administrator",
        "NUXEO_PASSWORD": "Administrator",
        "MCP_TRANSPORT": "stdio"
      },
      "transport": "stdio"
    }
  }
}
